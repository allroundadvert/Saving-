</td>
</tr>

</table>

<div class="buttons">
<button class="whatsapp-btn" onclick="sendOrder()">
SEND ORDER ON WHATSAPP
</button>
</div>

</div>

<footer>
© 2026 Del Smiles Kitchen & Varieties
</footer>

<script>
function sendOrder(){

    let rows = document.querySelectorAll("table tr");
    let message = "🛒 *NEW ORDER - DEL SMILES KITCHEN & VARIETIES*%0A%0A";

    rows.forEach(row => {
        let item = row.querySelector(".item");
        let qty = row.querySelector(".qty");
        let spec = row.querySelector(".spec");
        let name = row.querySelector("th");

        if(item && item.checked){
            let itemName = name.innerText;
            let quantity = qty.value || "1";
            let specValue = spec.value || "No specification";

            message += `✔ ${itemName}%0AQty: ${quantity}%0ASpec: ${specValue}%0A%0A`;
        }
    });

    let phone = "2348067515299";
    let url = `https://wa.me/${phone}?text=${message}`;

    window.open(url, "_blank");
}
</script>

</body>
</html>
