<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Del Smiles Kitchen & Varieties</title>

<style>
body{
    margin:0;
    font-family:Arial,sans-serif;
    background:#111;
    color:#fff;
}

:root{
    --gold:#d4af37;
}

header{
    background:linear-gradient(90deg,#111,var(--gold),#111);
    text-align:center;
    padding:25px 15px;
}

header h1{
    margin:0;
    color:#111;
    font-size:28px;
    font-weight:900;
}

header p{
    margin:6px 0;
    color:#111;
    font-weight:bold;
}

.container{
    width:95%;
    max-width:1000px;
    margin:25px auto;
    background:#1a1a1a;
    border:1px solid var(--gold);
    border-radius:10px;
    padding:20px;
}

h2{
    text-align:center;
    color:var(--gold);
}

table{
    width:100%;
    border-collapse:collapse;
    margin-top:15px;
}

table,th,td{
    border:1px solid var(--gold);
}

th{
    background:var(--gold);
    color:#111;
    padding:12px;
    text-align:left;
}

td{
    padding:10px;
    background:#111;
}

input, textarea{
    padding:6px;
    background:#000;
    border:1px solid var(--gold);
    color:#fff;
    width:100%;
    box-sizing:border-box;
}

textarea{
    height:60px;
    resize:none;
}

/* BUTTON */
.buttons{
    margin-top:20px;
    text-align:center;
}

.whatsapp-btn{
    display:inline-block;
    background:#25d366;
    color:#fff;
    padding:12px 20px;
    text-decoration:none;
    border-radius:5px;
    font-weight:bold;
    border:none;
    cursor:pointer;
}

footer{
    text-align:center;
    padding:20px;
    color:#999;
}
</style>
</head>

<body>

<header>
<h1>DEL SMILES KITCHEN & VARIETIES</h1>
<p>Specialized in all kinds of kitchen utensils and household items</p>
<p><strong>Address:</strong> Igbagwe Road, Benin City, Edo State, Nigeria</p>
</header>

<div class="container">

<h2>Order Form</h2>

<table>

<tr>
<th>Pots</th>
<td>
<input type="checkbox" class="item">
<input type="number" class="qty" placeholder="Qty">
<textarea class="spec" placeholder="Specifications (size, type, etc)"></textarea>
</td>
</tr>

<tr>
<th>Blenders</th>
<td>
<input type="checkbox" class="item">
<input type="number" class="qty" placeholder="Qty">
<textarea class="spec"></textarea>
</td>
</tr>

<tr>
<th>Back to School</th>
<td>
<input type="checkbox" class="item">
<input type="number" class="qty" placeholder="Qty">
<textarea class="spec"></textarea>
</td>
</tr>

<tr>
<th>Luxury Bags</th>
<td>
<input type="checkbox" class="item">
<input type="number" class="qty" placeholder="Qty">
<textarea class="spec"></textarea>
</td>
</tr>

<tr>
<th>Shoes</th>
<td>
<input type="checkbox" class="item">
<input type="number" class="qty" placeholder="Qty">
<textarea class="spec"></textarea>
</td>
</tr>

<tr>
<th>Solar Fans</th>
<td>
<input type="checkbox" class="item">
<input type="number" class="qty" placeholder="Qty">
<textarea class="spec"></textarea>
</td>
</tr>

<tr>
<th>Nonstick Pots</th>
<td>
<input type="checkbox" class="item">
<input type="number" class="qty" placeholder="Qty">
